{
    "file_extensions": [
        ".py",
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".java",
        ".cpp",
        ".c",
        ".h",
        ".hpp",
        ".go",
        ".rs",
        ".rb",
        ".php"
    ],
    "ignore_patterns": [
        "**/node_modules/**",
        "**/venv/**",
        "**/__pycache__/**",
        "**/build/**",
        "**/dist/**",
        "**/target/**",
        "**/.git/**",
        "**/coverage/**",
        "**/.pytest_cache/**",
        "**/vendor/**"
    ],
    "ignore_files": [
        ".gitignore",
        ".gitattributes", 
        "README.md",
        "README.rst",
        "README.txt",
        "LICENSE",
        "LICENSE.txt",
        "LICENSE.md",
        "requirements.txt",
        "package.json",
        "package-lock.json",
        "yarn.lock",
        "Cargo.toml",
        "Cargo.lock",
        "go.mod",
        "go.sum",
        "pom.xml",
        "build.gradle",
        "Makefile",
        "CMakeLists.txt",
        "Dockerfile",
        ".dockerignore"
    ],
    "entry_points": [
        "main.py",
        "app.py",
        "__main__.py",
        "manage.py",
        "server.py",
        "index.js",
        "main.js",
        "app.js",
        "server.js",
        "index.ts",
        "main.ts",
        "Main.java",
        "Application.java",
        "main.cpp",
        "main.c"
    ],
    "exclude_patterns": [
        "test_*",
        "*_test.*",
        "*.test.*",
        "*.spec.*",
        "*Test.*",
        "*Tests.*",
        "conftest.py"
    ]
}